# ============================================================
#  Roboadvisor — Environment Variable Template
#  Copy this file to .env and fill in real values:
#    cp .env.example .env
# ============================================================

# ── Required ────────────────────────────────────────────────

# A placeholder key for financial data providers (e.g. Alpha Vantage, Twelve
# Data).  Currently the pipeline uses yfinance which does not require a key,
# but this field is validated on startup to encourage explicit configuration.
FINANCE_API_KEY=your_finance_api_key_here

# NewsAPI key — obtain a free key at https://newsapi.org/
NEWS_API_KEY=your_newsapi_key_here

# ── Optional ────────────────────────────────────────────────

# Anthropic API key — enables LLM-driven commentary in reports.
# Get one at https://console.anthropic.com/
# Leave blank to run without LLM features.
ANTHROPIC_API_KEY=

# ── Overridable defaults ────────────────────────────────────

# Path to the SQLite database file (relative to working directory)
# DB_PATH=roboadvisor.db

# Logging level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
